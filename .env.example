# Narrative Nexus — Environment Variables
#
# Copy to .env and fill in values. All keys are optional — the application
# starts without them and the scraper + pipeline agents degrade gracefully.

# ── Provider API keys (optional) ────────────────────────────────────────
# FIREWORKS_API_KEY=           # Fireworks.ai (LLM + embeddings)
# FIRECRAWL_API_KEY=           # Firecrawl (web scraping)
# DEEPSEEK_API_KEY=            # DeepSeek (LLM)
# OPENAI_API_KEY=              # OpenAI (LLM)

# ── Hosting-only guard ───────────────────────────────────────────────────
# Set to "1" on shared / hosted deployments to disable the scraper.
# Any visitor clicking "Start" would mutate the shared DB.
# Default (unset): scraper is enabled (local / single-user deployments).
NN_DISABLE_SCRAPER=
